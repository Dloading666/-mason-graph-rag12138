APP_NAME=MasonGraphRAG
DEV_MODE=true
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

QWEN_API_KEY=
QWEN_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
QWEN_MODEL=qwen3.5-plus
QWEN_TEMPERATURE=0.1
QWEN_MAX_TOKENS=1200
QWEN_TIMEOUT_SECONDS=60

EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=1024
EMBEDDING_TIMEOUT_SECONDS=30

# Fastest local option
DATABASE_URL=sqlite:///backend/data/state/mason_graph_rag.db
# MySQL example
# DATABASE_URL=mysql+pymysql://mason:mason_password@localhost:3306/mason_graph_rag?charset=utf8mb4
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=true

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=mason-knowledge
MINIO_SECURE=false
MINIO_ENABLED=false

NEO4J_ENABLED=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

DOCUMENT_STORAGE_DIR=backend/data/uploads
DOCUMENT_INDEX_FILE=backend/data/state/documents.json

ENABLE_ADVANCED_GRAPHRAG=true
ENABLE_DEBUG_TRACES=true
ENABLE_ASYNC_INGESTION=true
ENABLE_EVALUATION=true
